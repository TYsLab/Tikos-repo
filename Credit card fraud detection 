    {
      "cell_type": "markdown",
      "source": [
        "##Splitting Data\n",
        "\n",
        "\n",
        "---\n",
        "\n",
        "Data split into Train & Test sets\n",
        "\n",
        "Normal & Fraudulant Transactions split:\n",
        "*   Class 0 = Normal Transaction\n",
        "*   Class 1 = Fraudulant Transaction"
      ],
      "metadata": {
        "id": "eYxyNY1nROmE"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Separate features and target\n",
        "X = fraud_set.drop('Class', axis=1)\n",
        "y = fraud_set['Class']\n",
        "\n",
        "# Scale 'Time' and 'Amount' features\n",
        "scaler = StandardScaler()\n",
        "X[['Time', 'Amount']] = scaler.fit_transform(X[['Time', 'Amount']])\n",
        "\n",
        "# Separate normal and fraudulent transactions (comes from 'class' section in dataset)\n",
        "  # Class 0 being legitimate transactions\n",
        "  # Class 1 being fraudulant transactions\n",
        "normal_transactions = X[y == 0]\n",
        "fraud_transactions = X[y == 1]\n",
        "\n",
        "print(f\"Number of normal transactions: {len(normal_transactions)}\")\n",
        "print(f\"Number of fraudulent transactions: {len(fraud_transactions)}\")\n",
        "\n",
        "# Split normal transactions into training and validation sets\n",
        "X_train, X_val = train_test_split(normal_transactions, test_size=0.2, random_state=42)\n"
      ],
